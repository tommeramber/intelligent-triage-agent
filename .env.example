# Copy this file to .env for local development.
# NEVER commit the real .env to git — it contains your API key.

# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here

# ── Optional overrides (defaults shown) ──────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=1024
AGENT_MAX_ITERATIONS=3
DOCS_FILE_PATH=data/troubleshooting_docs.json
APP_HOST=0.0.0.0
APP_PORT=8080
APP_VERSION=1.0.0
LOG_LEVEL=info
# LLM_TEMPERATURE: 0.0=deterministic/no hallucinations, 2.0=very creative. Keep low (0.0-0.3) for reproducible triage.
LLM_TEMPERATURE=0.2
