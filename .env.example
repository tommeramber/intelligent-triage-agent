# Copy this file to .env for local development.
# NEVER commit the real .env to git — it contains your API key.

# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here

# ── Optional overrides (defaults shown) ──────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=1024
AGENT_MAX_ITERATIONS=4
DOCS_FILE_PATH=data/troubleshooting_docs.json
APP_HOST=0.0.0.0
APP_PORT=8080
APP_VERSION=1.0.0
LOG_LEVEL=info
# LLM_TEMPERATURE: 0.0=deterministic/no hallucinations, 2.0=very creative. Keep low (0.0-0.3) for reproducible triage.
LLM_TEMPERATURE=0.2

# ── MCP (KB stdio server runs in same process tree; K8s optional on host) ─────
MCP_KB_ENABLED=true
# MCP_PYTHONPATH=          # empty = project root when running locally
# MCP_WORKDIR=
K8S_MCP_ENABLED=false
# K8S_MCP_COMMAND=python3
# K8S_MCP_ARGS=-m mcp_servers.k8s_server
# K8S_MCP_KUBECONFIG=          # local dev only; in-cluster uses pod SA
# K8S_ACCESS_LABEL_KEY=triage.agent-accessible
# K8S_ACCESS_LABEL_VALUE=true
# K8S_ACCESS_ALLOWLIST=        # set by make k8s-sync-access in cluster demos
